    "os.makedirs(BASE_PATH, exist_ok=True)\n",
    "os.chdir(BASE_PATH)\n",
    "print(f\"\\n✅ Working directory: {os.getcwd()}\")\n",
    "print(f\"All outputs will be saved to: {BASE_PATH}\")\n",
    "print(\"\\nCurrent folder contents:\")\n",
    "!ls -la"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
